# === API para informes (Groq - gratis) ===
# 1. Ve a https://console.groq.com (gratis, sin tarjeta)
# 2. Crea cuenta → API Keys → Create API Key
# 3. Copia la key y pega aquí
GROQ_API_KEY=your_key_here

# === API para scraping (ZenRows - gratis 1000 req/mes) ===
# 1. Ve a https://zenrows.com (gratis, sin tarjeta)
# 2. Crea cuenta → Dashboard → API Key
# 3. Copia la key y pega aquí
# ZENROWS_API_KEY=
